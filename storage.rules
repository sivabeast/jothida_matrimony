rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Each user owns everything under profiles/{uid}/** — profile photos,
    // horoscope PDFs/images, and ID-proof documents (matches the paths used
    // by StorageService: profiles/{userId}/photos|horoscope|id_proof/...).
    match /profiles/{userId}/{allPaths=**} {
      // Approved profile photos are shown to any signed-in user; the owner
      // can read/write everything in their own folder (including
      // not-yet-approved horoscope/ID docs).
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Astrologer profile/verification documents.
    match /astrologers/{astrologerId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == astrologerId;
    }
  }
}
