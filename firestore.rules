rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      // 'super_admin' has the same data privileges as 'admin'. Without this,
      // every admin query is rejected with permission-denied.
      return isAuthenticated() &&
          getUserData().role in ['admin', 'super_admin'];
    }

    function isAstrologer() {
      return isAuthenticated() && getUserData().role == 'astrologer';
    }

    // Deterministic id of the connection between two users (sorted, '_'-joined)
    // so it can be looked up from either side.
    function pairId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    // ── Master location data (states / districts / cities) ────────────────
    // Read-only REFERENCE data that powers the cascading State → District →
    // City pickers. Any signed-in user may read it; only admins maintain it.
    // App queries: master_states (all) · master_districts where stateId == X ·
    // master_cities where districtId == X — all allowed by the open read.
    match /master_states/{stateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_districts/{districtId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_cities/{cityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // A user can only read/write their OWN account document. Admins may read
    // any user (for moderation); only admins may delete.
    // BUSINESS RULE: astrologers must NEVER browse the user database, so they
    // have NO read access here (previously granted via isAdminOrAstrologer).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      // Self-service account deletion: a user may delete their OWN account
      // document immediately (no admin approval). Admins may delete any.
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── Profiles ─────────────────────────────────────────────────────────
    // Public profile data (no contact details — those live in /contacts) is
    // visible to signed-in MATRIMONY users. Astrologers must not browse the
    // user database, so the blanket astrologer read was removed; only admins
    // get full read access for moderation.
    match /profiles/{profileId} {
      allow read: if isAuthenticated()
                  && resource.data.status == 'approved'
                  && resource.data.isActive == true;
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      // Any signed-in user may bump engagement counters (view / interest
      // counts) on a profile they can read — but NOTHING else. This powers
      // incrementViewCount without exposing the rest of the document to edits.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['viewCount', 'interestCount', 'updatedAt']);
      allow update: if isAdmin();
      // The owner may delete their own profile (self-service account deletion);
      // admins may delete any profile for moderation.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid);
    }

    // ── Contacts (phone / WhatsApp) ───────────────────────────────────────
    // A user's contact details live OUTSIDE their public profile so they are
    // NEVER exposed by browsing. They unlock for another user only after an
    // interest between the two has been accepted — i.e. a matching
    // /connections/{pair} document exists. (User Premium "contact unlock"
    // also flows through an accepted connection.)
    match /contacts/{ownerId} {
      allow read: if isOwner(ownerId)
                  || isAdmin()
                  || (isAuthenticated()
                      && exists(/databases/$(database)/documents/connections/$(pairId(ownerId, request.auth.uid))));
      allow create, update: if isOwner(ownerId);
      allow delete: if isOwner(ownerId) || isAdmin();
    }

    // ── Connections (mutual-acceptance contact unlock) ─────────────────────
    // Created when an interest between two users is accepted. A participant may
    // create it ONLY when the referenced interest is actually 'accepted' and
    // both of its parties are the two members of the connection — which blocks
    // a user from self-granting access to an unrelated person's contact.
    match /connections/{connId} {
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.uids;
      allow create: if isAuthenticated()
        && request.resource.data.uids.size() == 2
        && request.auth.uid in request.resource.data.uids
        && get(/databases/$(database)/documents/interests/$(request.resource.data.interestId)).data.status == 'accepted'
        && get(/databases/$(database)/documents/interests/$(request.resource.data.interestId)).data.senderId in request.resource.data.uids
        && get(/databases/$(database)/documents/interests/$(request.resource.data.interestId)).data.receiverId in request.resource.data.uids;
      // A participant may delete their own connection (account deletion cleanup);
      // admins may delete any.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && request.auth.uid in resource.data.uids);
    }

    // ── Master data (religions / castes / subcastes) ──────────────────────
    // Public reference data: any signed-in user may read; only admins write.
    // Seeded via scripts in master_data/seed_master_data.js.
    match /master_religions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_castes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_subcastes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Interests ─────────────────────────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAuthenticated()
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);
      // Admins may read interests for moderation + dashboard engagement counts.
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.receiverId == request.auth.uid;
      // Either party may delete the interest — the sender withdrawing it, or
      // either party clearing it during account deletion.
      allow delete: if isAuthenticated()
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
    }

    // ── Subscriptions ─────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Poruthams ─────────────────────────────────────────────────────────
    // Horoscope-match requests belong to the requesting user. Astrologers do
    // NOT get blanket access (user-data browsing); only the owner + admins.
    match /poruthams/{id} {
      allow read: if isAuthenticated()
                  && resource.data.requestedByUserId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.requestedByUserId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Reports ───────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.reporterUserId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Account deletion requests ─────────────────────────────────────────
    // A user files a request to delete their OWN account; only admins
    // (super_admin) can review, approve or reject them.
    match /account_deletion_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      // The owner may clear their own (stale) request as part of self-service
      // account deletion; admins may delete any.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid);
    }

    // ── Announcements (admin broadcast → all users & astrologers) ──────────
    // Any signed-in account may READ; only admins create / edit / delete.
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────
    // BUSINESS RULE: astrologers must not contact users. Notifications are
    // therefore created only by admins / privileged server logic — never by an
    // astrologer pushing a message to a user.
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // ── Transactions ──────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    // ── Astrologers ───────────────────────────────────────────────────────
    // VISIBILITY RULE: astrologer listings are public BUSINESS profiles — any
    // signed-in user may browse the directory. (A collection query that did not
    // filter by status previously failed with permission-denied because the rule
    // only allowed reading 'approved' docs; Firestore rejects the whole query
    // unless every matched doc is readable. Allowing any authenticated read lets
    // the directory load regardless of the client's query filters.)
    // Writes stay locked down: an astrologer creates/edits ONLY their own
    // document, and only admins may delete.
    match /astrologers/{astrologerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(astrologerId);
      allow update: if isOwner(astrologerId) || isAdmin();
      // Any signed-in user may update ONLY the aggregate rating fields (so a
      // rating recompute can write back the new average / count) — nothing else
      // on the document is editable by a non-owner. Mirrors the profiles
      // viewCount pattern.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['rating', 'reviewCount', 'ratingBreakdown',
                                  'bookingCount', 'updatedAt']);
      // Self-service account deletion: an astrologer may delete their OWN
      // account document immediately. Admins may delete any.
      allow delete: if isOwner(astrologerId) || isAdmin();

      // ── Astrologer reviews (subcollection) ──────────────────────────────
      // astrologers/{astrologerId}/reviews/{userId}. The document id is the
      // rater's uid → exactly one review per user per astrologer, and ownership
      // is enforced straight from the path. Anyone signed in may READ. Only a
      // normal USER may create/edit their OWN review (uid must match the doc id
      // and the userId field); astrologers and admins can never rate. The
      // profile-completed gate is enforced in the app; ownership + role + a
      // valid 1–5 rating are enforced here.
      match /reviews/{userId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated()
                      && request.auth.uid == userId
                      && getUserData().role == 'user'
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.rating is int
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5;
        allow delete: if isAdmin()
                      || (isAuthenticated() && request.auth.uid == userId);
      }

      // ── Booked-slots availability index (subcollection) ─────────────────
      // astrologers/{astrologerId}/booked_slots/{dateKey} holds only the taken
      // slot keys for a date (no PII), so any signed-in user can READ it to
      // grey out taken slots. A signed-in user may add/remove a slot key when
      // booking/cancelling (the authoritative one-per-slot lock is the
      // deterministic consultation doc id, so this index is best-effort UX).
      match /booked_slots/{dateKey} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || isOwner(astrologerId);
      }
    }

    // ── Consultations (In-App + Direct Visit booking system) ─────────────
    // USER → ASTROLOGER. The user creates the booking; both parties (and admins)
    // can read it; the astrologer responds and submits the report; the user can
    // pay / cancel. Payment is collected only AFTER acceptance.
    match /consultations/{consultationId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.astrologerId == request.auth.uid);
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      // The addressed astrologer may respond / run the analysis / submit report.
      allow update: if isAuthenticated()
                    && resource.data.astrologerId == request.auth.uid;
      // The booking owner may pay / cancel their own booking.
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && (resource.data.astrologerId == request.auth.uid
                            || resource.data.userId == request.auth.uid));
    }

    // ── Astrologer requests (consultation / inquiry / matching) ──────────
    // Direction is USER → ASTROLOGER: only the user creates a request; the
    // astrologer may only respond (accept/complete/reject) to requests
    // addressed to them.
    match /astrologer_requests/{requestId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.astrologerId == request.auth.uid);
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.astrologerId == request.auth.uid;
      allow update: if isAdmin();
      // The booking's owner (matrimony user) may run the client-side expiry
      // sweep, pay the analysis fee (dev-mode payment flags), and — for "choose
      // another later" bookings — reassign it to a new astrologer. Restricted to
      // these workflow fields so they can never edit the analysis, amount,
      // profiles, etc.
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly([
                           'expired', 'expiredAt', 'history', 'status',
                           'astrologerId', 'astrologerName', 'reassigned',
                           'reassignedAt', 'respondedAt', 'expiresAt',
                           'paid', 'paidAt', 'paymentId'
                         ]);
      // Either party may delete their own request as part of account deletion;
      // admins may delete any.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && (resource.data.astrologerId == request.auth.uid
                            || resource.data.userId == request.auth.uid));
    }

    // ── Bookings / appointments ───────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.astrologerId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid
                        || resource.data.astrologerId == request.auth.uid);
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    // Only the two participants may read or write a thread / its messages.
    // BUSINESS RULE: astrologers must not COLD-initiate contact, so an
    // astrologer cannot CREATE a thread. The match-analysis flow still gets its
    // automatic "booking accepted" message because the thread is pre-created by
    // the USER at booking time — the astrologer only SENDS into that existing
    // thread on accept (allowed below for any participant), never creating one.
    match /chats/{threadId} {
      allow read, update: if isAuthenticated()
                          && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participantIds
                    && !isAstrologer();

      match /messages/{messageId} {
        allow read: if isAuthenticated()
                    && request.auth.uid in
                        get(/databases/$(database)/documents/chats/$(threadId))
                            .data.participantIds;
        allow create: if isAuthenticated()
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in
                          get(/databases/$(database)/documents/chats/$(threadId))
                              .data.participantIds;
      }
    }
  }
}
