rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isAstrologer() {
      return isAuthenticated() && getUserData().role == 'astrologer';
    }

    function isAdminOrAstrologer() {
      return isAdmin() || isAstrologer();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // A user can only read/write their OWN account document. Admins and
    // astrologers may read any user (for moderation); only admins may delete.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrAstrologer();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Profiles ─────────────────────────────────────────────────────────
    match /profiles/{profileId} {
      allow read: if isAuthenticated()
                  && resource.data.status == 'approved'
                  && resource.data.isActive == true;
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdminOrAstrologer();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Interests ─────────────────────────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAuthenticated()
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.receiverId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.senderId == request.auth.uid;
    }

    // ── Subscriptions ─────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Poruthams ─────────────────────────────────────────────────────────
    match /poruthams/{id} {
      allow read: if isAuthenticated()
                  && resource.data.requestedByUserId == request.auth.uid;
      allow read: if isAdminOrAstrologer();
      allow create: if isAuthenticated()
                    && request.resource.data.requestedByUserId == request.auth.uid;
      allow update: if isAdminOrAstrologer();
    }

    // ── Reports ───────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.reporterUserId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow create: if isAdminOrAstrologer();
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // ── Transactions ──────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }
  }
}
