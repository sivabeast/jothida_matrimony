rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      // 'super_admin' has the same data privileges as 'admin'. Without this,
      // every admin query is rejected with permission-denied.
      return isAuthenticated() &&
          getUserData().role in ['admin', 'super_admin'];
    }

    function isAstrologer() {
      return isAuthenticated() && getUserData().role == 'astrologer';
    }

    // NOTE: there is no email-based astrology access anymore — the old
    // internal astrology account was removed. Requests addressed to the
    // synthetic 'internal_astrology' id are managed by ADMINS only.

    // Deterministic id of the connection between two users (sorted, '_'-joined)
    // so it can be looked up from either side.
    function pairId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    // ── Master location data (states / districts / cities) ────────────────
    // Read-only REFERENCE data that powers the cascading State → District →
    // City pickers. Any signed-in user may read it; only admins maintain it.
    // App queries: master_states (all) · master_districts where stateId == X ·
    // master_cities where districtId == X — all allowed by the open read.
    match /master_states/{stateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_districts/{districtId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_cities/{cityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Custom master-dropdown values ("+ Add" system) ─────────────────────
    // One doc per dropdown type (master_options/education, /caste, /city, …)
    // holding user-added values that the canonical (bundled) master data is
    // missing. Any signed-in user may append a value; entries stream live to
    // every user, search, filters and the admin panel. Only admins may delete.
    match /master_options/{type} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
                            && request.resource.data.entries is list;
      allow delete: if isAdmin();
    }

    // ── Aadhaar verification (SENSITIVE — never public) ────────────────────
    // aadhaar/{userId} = { number, frontUrl, backUrl, verified, updatedAt }.
    // Readable ONLY by the owner and admins. The owner may create/update their
    // own document but can never mark it verified themselves — editing resets
    // verification, and only an admin can set verified = true.
    match /aadhaar/{userId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow read: if isAdmin();
      allow create, update: if isAuthenticated()
                            && userId == request.auth.uid
                            && request.resource.data.verified == false;
      allow write: if isAdmin();
    }

    // ── Website settings (marketing site) ──────────────────────────────────
    // Single config doc (website_settings/general) driving the public
    // marketing website: launch status/message, store URLs, hero image,
    // app screenshots, contact info and social links. Content here is
    // non-sensitive and meant to be publicly visible on the site before a
    // visitor has even signed in (anonymously or otherwise), so read is
    // fully public. Only admins may edit it.
    match /website_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Contact messages (marketing-site contact form) ────────────────────
    // Any signed-in visitor (including the anonymous public session) may
    // SUBMIT a message; only admins may read them or change read/unread
    // status. Deploy with: firebase deploy --only firestore:rules
    match /contact_messages/{messageId} {
      allow create: if isAuthenticated()
                    && request.resource.data.status == 'unread';
      allow read, update, delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // A user can only read/write their OWN account document. Admins may read
    // any user (for moderation); only admins may delete.
    // BUSINESS RULE: astrologers must NEVER browse the user database, so they
    // have NO read access here (previously granted via isAdminOrAstrologer).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      // Self-service account deletion: a user may delete their OWN account
      // document immediately (no admin approval). Admins may delete any.
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ── Profiles ─────────────────────────────────────────────────────────
    // Public profile data (no contact details — those live in /contacts) is
    // visible to signed-in MATRIMONY users. Astrologers must not browse the
    // user database, so the blanket astrologer read was removed; only admins
    // get full read access for moderation.
    match /profiles/{profileId} {
      allow read: if isAuthenticated()
                  && resource.data.status == 'approved'
                  && resource.data.isActive == true;
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      // Any signed-in user may bump engagement counters (view / interest
      // counts) on a profile they can read — but NOTHING else. This powers
      // incrementViewCount without exposing the rest of the document to edits.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['viewCount', 'interestCount', 'updatedAt']);
      allow update: if isAdmin();
      // The owner may delete their own profile (self-service account deletion);
      // admins may delete any profile for moderation.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid);
    }

    // ── Contacts (phone / WhatsApp) ───────────────────────────────────────
    // A user's contact details live OUTSIDE their public profile so they are
    // NEVER exposed by browsing. They unlock for another user only after an
    // interest between the two has been accepted — i.e. a matching
    // /connections/{pair} document exists. (User Premium "contact unlock"
    // also flows through an accepted connection.)
    match /contacts/{ownerId} {
      allow read: if isOwner(ownerId)
                  || isAdmin()
                  || (isAuthenticated()
                      && exists(/databases/$(database)/documents/connections/$(pairId(ownerId, request.auth.uid))));
      // Admins may edit a member's contact details too — the Admin panel's
      // "Edit User Profile" saves contact fields here; without this the save
      // fails with permission-denied after the profile update succeeded.
      allow create, update: if isOwner(ownerId) || isAdmin();
      allow delete: if isOwner(ownerId) || isAdmin();
    }

    // ── Connections (mutual-acceptance contact unlock) ─────────────────────
    // Created when an interest between two users is accepted. A participant may
    // create it ONLY when the referenced interest is actually 'accepted' and
    // both of its parties are the two members of the connection — which blocks
    // a user from self-granting access to an unrelated person's contact.
    match /connections/{connId} {
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.uids;
      allow create: if isAuthenticated()
        && request.resource.data.uids.size() == 2
        && request.auth.uid in request.resource.data.uids
        && get(/databases/$(database)/documents/interests/$(request.resource.data.interestId)).data.status == 'accepted'
        && get(/databases/$(database)/documents/interests/$(request.resource.data.interestId)).data.senderId in request.resource.data.uids
        && get(/databases/$(database)/documents/interests/$(request.resource.data.interestId)).data.receiverId in request.resource.data.uids;
      // A participant may delete their own connection (account deletion cleanup);
      // admins may delete any.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && request.auth.uid in resource.data.uids);
    }

    // ── Master data (religions / castes / subcastes) ──────────────────────
    // Public reference data: any signed-in user may read; only admins write.
    // Seeded via scripts in master_data/seed_master_data.js.
    match /master_religions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_castes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /master_subcastes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Interests ─────────────────────────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAuthenticated()
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);
      // Admins may read interests for moderation + dashboard engagement counts.
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.receiverId == request.auth.uid;
      // Either party may delete the interest — the sender withdrawing it, or
      // either party clearing it during account deletion.
      allow delete: if isAuthenticated()
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
    }

    // ── Subscriptions ─────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Poruthams ─────────────────────────────────────────────────────────
    // Horoscope-match requests belong to the requesting user. Astrologers do
    // NOT get blanket access (user-data browsing); only the owner + admins.
    match /poruthams/{id} {
      allow read: if isAuthenticated()
                  && resource.data.requestedByUserId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.requestedByUserId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Reports ───────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.reporterUserId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Account deletion requests (RETIRED collection) ────────────────────
    // The admin-approval deletion workflow was removed — account deletion is
    // immediate and self-service. Only the legacy-cleanup delete remains so
    // deleting an account can purge any old request docs; nothing creates or
    // reads these any more.
    match /account_deletion_requests/{requestId} {
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid);
    }

    // ── Announcements (admin broadcast → all users & astrologers) ──────────
    // Any signed-in account may READ; only admins create / edit / delete.
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Home banners (admin-managed carousel) ──────────────────────────────
    // Admin has full control (add / edit / delete / publish / order); any
    // signed-in user may READ (the Home page filters to enabled banners).
    match /banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────
    // Event notifications (interest sent/accepted/rejected, profile approved,
    // report ready, appointment confirmed, admin update) are created
    // CLIENT-SIDE by the acting user, so any signed-in account may create a
    // WELL-FORMED notification document. Reading/updating/deleting stays
    // strictly owner-only.
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId is string
                    && request.resource.data.title is string
                    && request.resource.data.body is string
                    && request.resource.data.type is string
                    && request.resource.data.isRead == false;
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // ── Transactions ──────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated()
                  && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
    }

    // ── Astrologers ───────────────────────────────────────────────────────
    // VISIBILITY RULE: astrologer listings are public BUSINESS profiles — any
    // signed-in user may browse the directory. (A collection query that did not
    // filter by status previously failed with permission-denied because the rule
    // only allowed reading 'approved' docs; Firestore rejects the whole query
    // unless every matched doc is readable. Allowing any authenticated read lets
    // the directory load regardless of the client's query filters.)
    // Writes stay locked down: an astrologer creates/edits ONLY their own
    // document, and only admins may delete.
    match /astrologers/{astrologerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(astrologerId);
      allow update: if isOwner(astrologerId) || isAdmin();
      // Any signed-in user may update ONLY the aggregate rating fields (so a
      // rating recompute can write back the new average / count) — nothing else
      // on the document is editable by a non-owner. Mirrors the profiles
      // viewCount pattern.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['rating', 'reviewCount', 'ratingBreakdown',
                                  'bookingCount', 'updatedAt']);
      // Self-service account deletion: an astrologer may delete their OWN
      // account document immediately. Admins may delete any.
      allow delete: if isOwner(astrologerId) || isAdmin();

      // ── Astrologer reviews (subcollection) ──────────────────────────────
      // astrologers/{astrologerId}/reviews/{userId}. The document id is the
      // rater's uid → exactly one review per user per astrologer, and ownership
      // is enforced straight from the path. Anyone signed in may READ. Only a
      // normal USER may create/edit their OWN review (uid must match the doc id
      // and the userId field); astrologers and admins can never rate. The
      // profile-completed gate is enforced in the app; ownership + role + a
      // valid 1–5 rating are enforced here.
      match /reviews/{userId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated()
                      && request.auth.uid == userId
                      && getUserData().role == 'user'
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.rating is int
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5;
        allow delete: if isAdmin()
                      || (isAuthenticated() && request.auth.uid == userId);
      }

      // ── Booked-slots availability index (subcollection) ─────────────────
      // astrologers/{astrologerId}/booked_slots/{dateKey} holds only the taken
      // slot keys for a date (no PII), so any signed-in user can READ it to
      // grey out taken slots. A signed-in user may add/remove a slot key when
      // booking/cancelling (the authoritative one-per-slot lock is the
      // deterministic consultation doc id, so this index is best-effort UX).
      match /booked_slots/{dateKey} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || isOwner(astrologerId);
      }
    }

    // ── Consultations (In-App + Direct Visit booking system) ─────────────
    // USER → ASTROLOGER. The user creates the booking; both parties (and admins)
    // can read it; the astrologer responds and submits the report; the user can
    // pay / cancel. Payment is collected only AFTER acceptance.
    match /consultations/{consultationId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.astrologerId == request.auth.uid);
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      // The addressed astrologer may respond / run the analysis / submit report.
      allow update: if isAuthenticated()
                    && resource.data.astrologerId == request.auth.uid;
      // The booking owner may pay / cancel their own booking.
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && (resource.data.astrologerId == request.auth.uid
                            || resource.data.userId == request.auth.uid));
    }

    // ── Astrology service config ─────────────────────────────────────────
    // Single document (astrology_service/config) holding the expert profile,
    // office details, service charge, page copy and appointment sessions.
    // Any signed-in user may READ it (the service page + booking need it);
    // only an admin may write.
    match /astrology_service/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Astrology team (admin-provisioned astrologer accounts) ────────────
    // Doc id = the member's lowercased Gmail. Admins provision/enable/disable
    // members. Any signed-in user may READ (the smart auto-assigner picks the
    // lowest-pending member at booking time). Two narrowly-scoped self-service
    // writes are allowed:
    //   1. A member links their OWN uid on first Google sign-in (their email
    //      must equal the doc id), plus lastLoginAt / displayName / photoUrl.
    //   2. The booking user (or the submitting astrologer) updates ONLY the
    //      workload counters (pendingCount / lastAssignedAt) so the assignment
    //      stays balanced — they can touch nothing else on the document.
    match /astrology_team/{emailKey} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
      // An astrologer may delete their OWN registration (spec §5 delete account).
      allow delete: if isAuthenticated()
                    && request.auth.token.email.lower() == emailKey;
      // The member (matched by Gmail) manages their OWN profile + availability,
      // but never the admin-controlled `active` flag or the assignment counters.
      allow update: if isAuthenticated()
                    && request.auth.token.email.lower() == emailKey
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['uid', 'lastLoginAt', 'displayName',
                                   'photoUrl', 'available', 'about',
                                   'experience', 'qualification']);
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['pendingCount', 'lastAssignedAt',
                                   'lastSubmittedAt']);
    }

    // ── Appointment booked-slots index (no PII) ──────────────────────────
    // astrology_booked_slots/{dateKey} holds only the taken slot keys for a
    // date, so any signed-in user can grey out booked appointment slots without
    // reading other users' requests. A user adds their slot key when booking
    // (the authoritative one-per-slot lock is the deterministic appointment doc
    // id on astrologer_requests). Only admin/internal may delete.
    match /astrology_booked_slots/{dateKey} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Payroll payments (weekly employee-commission payouts) ─────────────
    // Written ONLY by the admin ("Mark As Paid" closes an employee's weekly
    // payroll cycle). The admin reads everything; an employee may read their
    // OWN payment history (matched by the Gmail their registry entry uses).
    match /payroll_payments/{paymentId} {
      allow read: if isAdmin()
                  || (isAuthenticated()
                      && resource.data.employeeEmail ==
                          request.auth.token.email.lower());
      allow create, update, delete: if isAdmin();
    }

    // ── Settlements (astrologer payout history) ──────────────────────────
    // The admin collects consultation payments and pays them out in full (no
    // commission). Each "Mark as Paid" batch writes one settlement doc. Only the
    // admin may write; the admin and the owning astrologer may read their own.
    match /settlements/{settlementId} {
      allow read: if isAdmin()
                  || (isAuthenticated()
                      && resource.data.astrologerId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // ── Astrologer requests (consultation / inquiry / matching) ──────────
    // Direction is USER → ASTROLOGER: only the user creates a request; the
    // astrologer may only respond (accept/complete/reject) to requests
    // addressed to them.
    match /astrologer_requests/{requestId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.astrologerId == request.auth.uid);
      // The assigned astrologer reads their OWN requests by the stable Gmail
      // stamped at assignment time (works even before their first uid link).
      // astrologerEmail is stored lowercased, so lower-case the token too.
      allow read: if isAuthenticated()
                  && resource.data.astrologerEmail ==
                      request.auth.token.email.lower();
      allow read: if isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.astrologerId == request.auth.uid;
      // The assigned astrologer (matched by Gmail) starts the analysis and
      // submits the report.
      allow update: if isAuthenticated()
                    && resource.data.astrologerEmail ==
                        request.auth.token.email.lower();
      allow update: if isAdmin();
      // The booking's owner (matrimony user) may run the client-side expiry
      // sweep, pay the analysis fee (dev-mode payment flags), reassign a "choose
      // another later" booking, AND trigger the automatic assignment of a newly
      // created Horoscope Compatibility Report to an employee (stamping the
      // assignment + workflow fields). Restricted to these workflow fields so
      // they can never edit the analysis, amount, profiles, etc.
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly([
                           'expired', 'expiredAt', 'history', 'status',
                           'astrologerId', 'astrologerName', 'astrologerUid',
                           'astrologerEmail', 'assignedAt', 'assignedBy',
                           'assignmentStatus', 'workflowStatus', 'inProgress',
                           'reassigned', 'reassignedAt', 'respondedAt',
                           'expiresAt', 'paid', 'paidAt', 'paymentId'
                         ]);
      // Either party may delete their own request as part of account deletion;
      // admins may delete any.
      allow delete: if isAdmin()
                    || (isAuthenticated()
                        && (resource.data.astrologerId == request.auth.uid
                            || resource.data.userId == request.auth.uid));
    }

    // ── Bookings / appointments ───────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.astrologerId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid
                        || resource.data.astrologerId == request.auth.uid);
    }

    // ── Weddings (Marriage Fixed → Wedding Workspace) ─────────────────────
    // weddings/{pairId} (sorted uids '_'-joined) is created when one partner
    // taps "Marriage Fixed" and unlocks (status 'fixed') when the other
    // confirms. Access:
    //   • the COUPLE (uid in coupleIds) — full read/update (confirmations,
    //     wedding date, family invitations);
    //   • invited FAMILY members (login gmail in memberEmails) — read the
    //     wedding + full access to the workspace subcollections;
    //   • admins — moderation.
    // Queries: coupleIds array-contains uid · memberEmails array-contains
    // email — both provable against the read rules below.
    match /weddings/{weddingId} {
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.coupleIds;
      allow read: if isAuthenticated()
                  && request.auth.token.email.lower()
                      in resource.data.memberEmails;
      allow read: if isAdmin();
      // Only one of the two matched users creates the wedding, and only for
      // a pair that includes themself.
      allow create: if isAuthenticated()
                    && request.resource.data.coupleIds.size() == 2
                    && request.auth.uid in request.resource.data.coupleIds;
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.coupleIds;
      // A family member may only flip their OWN invite status to 'joined'
      // (first login) — nothing else on the document.
      allow update: if isAuthenticated()
                    && request.auth.token.email.lower()
                        in resource.data.memberEmails
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['members']);
      // Cancel Marriage: either couple member may permanently delete the
      // wedding (the client first empties every workspace subcollection).
      allow delete: if isAuthenticated()
                    && request.auth.uid in resource.data.coupleIds;
      allow update, delete: if isAdmin();

      // ── Workspace subcollections ────────────────────────────────────────
      // Every workspace member (couple + invited family) collaborates with
      // full CRUD on these sections. Side-visibility (bride/groom/shared
      // scopes) and family-member permissions are enforced by the app's
      // role-based access control. Vendors and schedule are the exception
      // (couple-only writes, blocks below).
      match /{section}/{itemId} {
        allow read, write: if isAdmin();
        allow read, write: if isAuthenticated()
          && section in ['checklist', 'documents', 'contacts', 'guests',
                         'gallery', 'chat', 'galleryCategories',
                         'gallerySeen', 'expenses', 'events', 'notes',
                         'decisions', 'activity']
          && (request.auth.uid in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.coupleIds
              || request.auth.token.email.lower() in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.memberEmails);
      }
      // Wedding Day Schedule: everyone reads, only the couple manages.
      match /schedule/{itemId} {
        allow read: if isAuthenticated()
          && (request.auth.uid in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.coupleIds
              || request.auth.token.email.lower() in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.memberEmails);
        allow write: if isAuthenticated()
          && request.auth.uid in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.coupleIds;
        allow read, write: if isAdmin();
      }
      // Vendors: every workspace member may READ (per-vendor visibility is
      // enforced in the app via visibleTo), but ONLY the couple manages —
      // family members NEVER create, edit or delete vendors.
      match /vendors/{vendorId} {
        allow read: if isAuthenticated()
          && (request.auth.uid in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.coupleIds
              || request.auth.token.email.lower() in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.memberEmails);
        allow write: if isAuthenticated()
          && request.auth.uid in
                  get(/databases/$(database)/documents/weddings/$(weddingId))
                      .data.coupleIds;
        allow read, write: if isAdmin();
      }
    }

    // ── Wedding planning custom-item learning (GLOBAL) ─────────────────────
    // Family-contributed custom planning items, aggregated across weddings so
    // popular ones get promoted into the master template. Any authenticated
    // workspace user may read the approved catalogue and contribute an item
    // (create / merge usage). Only admins moderate (approve / reject) and
    // delete. Writes are constrained to the learning fields.
    match /wedding_plan_custom_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.status == 'pending';
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['weddingIds', 'usageCount', 'status',
                                   'updatedAt'])
                    // A normal user may only auto-promote by usage, never
                    // reject; explicit moderation is admin-only (below).
                    && request.resource.data.status in ['pending', 'approved'];
      allow update, delete: if isAdmin();
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    // Only the two participants may read or write a thread / its messages.
    // BUSINESS RULE: astrologers must not COLD-initiate contact, so an
    // astrologer cannot CREATE a thread. The match-analysis flow still gets its
    // automatic "booking accepted" message because the thread is pre-created by
    // the USER at booking time — the astrologer only SENDS into that existing
    // thread on accept (allowed below for any participant), never creating one.
    match /chats/{threadId} {
      allow read, update: if isAuthenticated()
                          && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participantIds
                    && !isAstrologer();

      match /messages/{messageId} {
        allow read: if isAuthenticated()
                    && request.auth.uid in
                        get(/databases/$(database)/documents/chats/$(threadId))
                            .data.participantIds;
        allow create: if isAuthenticated()
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in
                          get(/databases/$(database)/documents/chats/$(threadId))
                              .data.participantIds;
      }
    }
  }
}
