rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
          in ['admin', 'super_admin'];
    }

    // Profile media lives under profiles/{uid}/... (see StorageService:
    // profiles/{userId}/photos|horoscope|id_proof/...). Each subtree has its
    // own visibility — there is intentionally NO catch-all read so that
    // sensitive documents can't be exposed by a broad match.

    // Profile photos — shown to any signed-in user.
    match /profiles/{userId}/photos/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Horoscope PDFs / chart images — shown to any signed-in user.
    match /profiles/{userId}/horoscope/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // ID-proof documents — sensitive PII. Readable ONLY by the owner and
    // admins (previously readable by every signed-in user).
    match /profiles/{userId}/id_proof/{allPaths=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Astrologer profile photos + certificate documents. Certificates are
    // reviewed by admins; the astrologer's own public photo is visible to
    // signed-in users.
    match /astrologers/{astrologerId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == astrologerId;
    }
  }
}
